---
import type { CollectionEntry } from 'astro:content';
import SuitabilityBadge from './SuitabilityBadge.astro';
import type { ToolEntry, SourceEntry, SourceType } from '../lib/data';

type ResolvedSource = {
  label: string;
  url?: string;
  type: SourceType;
  type_label: string;
};

interface Props {
  stage: CollectionEntry<'stages'>;
  useCases: CollectionEntry<'use_cases'>[];
  tools: ToolEntry[];
  sources: SourceEntry[];
  standalone?: boolean;
}

const { stage, useCases: useCaseEntries, tools, sources, standalone = false } = Astro.props;
const { Content } = await stage.render();

const toolsById = new Map(tools.map((t) => [t.id, t] as const));
const sourcesById = new Map(sources.map((s) => [s.id, s] as const));

const maturityLabels: Record<string, string> = {
  production: 'stable',
  experimental: 'growing',
};

const sourceTypeLabels: Record<SourceType, string> = {
  study: 'study',
  case_study: 'case study',
  vendor: 'vendor',
  vendor_doc: 'vendor doc',
  community: 'community',
  review: 'review',
  blog: 'blog',
  documentation: 'docs',
  news: 'news',
};

const enterpriseReadinessLabels: Record<string, string> = {
  enterprise_ready: 'enterprise-ready',
  team_ready: 'team-ready',
  evaluation_only: 'nur Evaluation',
  irrelevant_for_enterprise: 'kein Enterprise-Fokus',
  unknown: 'Reifegrad unklar',
};

const adoptionLabels: Record<string, string> = {
  mainstream: 'Mainstream',
  growing: 'wachsend',
  emerging: 'aufkommend',
};

const relevanceLabels: Record<string, string> = {
  high: 'hoch',
  medium: 'mittel',
  low: 'niedrig',
};

const evidenceStrengthLabels: Record<string, string> = {
  strong: 'stark',
  medium: 'mittel',
  weak: 'schwach',
};

const tenorLabels: Record<string, string> = {
  positive: 'positiv',
  mixed: 'gemischt',
  polarized: 'polarisiert',
  negative: 'negativ',
  unknown: 'unklar',
};

const volumeLabels: Record<string, string> = {
  high: 'hoch',
  medium: 'mittel',
  low: 'niedrig',
};

const resolveSources = (
  refs: readonly { id: string }[] | undefined
): ResolvedSource[] =>
  (refs ?? [])
    .map((r) => sourcesById.get(r.id))
    .filter((s): s is SourceEntry => Boolean(s))
    .map(({ label, url, type }) => ({
      label,
      url,
      type,
      type_label: sourceTypeLabels[type] ?? type,
    }));

const useCases = useCaseEntries.map((entry) => entry.data);
---
<article class="stage-detail-body">
  <div class="stage-crumb">Atlas · Stage-Detail</div>
  <header class="stage-detail-header">
    <h2 class="stage-detail-title">{stage.data.name}</h2>
  </header>
  <p class="stage-verdict">{stage.data.challenge}</p>

  <section class="stage-detail-section">
    <h3>
      Use Cases
      <span class="count">{useCases.length} Einträge</span>
    </h3>
    <ul class="ucs">
      {useCases.map((uc) => {
        const ucSources = resolveSources(uc.sources);
        return (
        <li class="uc">
          <h4>{uc.title}</h4>
          <div class="goal">„{uc.goal_label}"</div>
          <div class="row pill-row">
            <SuitabilityBadge suitability={uc.suitability} />
          </div>
          {(uc.adoption_maturity || uc.enterprise_relevance || uc.evidence_strength) && (
            <div class="uc-meta">
              {uc.adoption_maturity && (
                <span>Adoption <b>{adoptionLabels[uc.adoption_maturity]}</b></span>
              )}
              {uc.enterprise_relevance && (
                <span>Enterprise-Relevanz <b>{relevanceLabels[uc.enterprise_relevance]}</b></span>
              )}
              {uc.evidence_strength && (
                <span>Evidenz <b>{evidenceStrengthLabels[uc.evidence_strength]}</b></span>
              )}
            </div>
          )}
          <p class="why">{uc.rationale}</p>

          <div class="kv">
            <b>Tools</b>
            <ul class="tool-entries">
              {uc.tools.map((entry) => {
                const tool = toolsById.get(entry.id);
                if (!tool) return null;
                const toolSources = resolveSources(entry.sources);
                const ps = entry.practitioner_signal;
                return (
                  <li class="tool-entry">
                    <div class="tool-head">
                      <a
                        class="chip"
                        href={tool.url}
                        rel="noreferrer"
                        target="_blank"
                      >
                        {tool.name}
                        {tool.vendor && <span class="vendor">· {tool.vendor}</span>}
                        <span class="mat">({maturityLabels[tool.maturity]})</span>
                      </a>
                      <SuitabilityBadge suitability={entry.fit} />
                      {entry.enterprise_readiness && (
                        <span class="pill neutral">
                          <span class="dot" aria-hidden="true"></span>
                          {enterpriseReadinessLabels[entry.enterprise_readiness]}
                        </span>
                      )}
                      {entry.confidence && (
                        <span class="tool-confidence">Confidence: {entry.confidence}</span>
                      )}
                    </div>
                    <p class="tool-why">{entry.why_it_fits}</p>
                    {entry.caveats && entry.caveats.length > 0 && (
                      <ul class="tool-caveats">
                        {entry.caveats.map((c) => (
                          <li>{c}</li>
                        ))}
                      </ul>
                    )}
                    {ps && (
                      <div class="tool-signal">
                        <div class="tool-signal-head">
                          Praktiker-Signal · Volumen <b>{volumeLabels[ps.volume]}</b> · Tenor <b>{tenorLabels[ps.tenor]}</b>
                        </div>
                        {(ps.praise?.length || ps.complaints?.length) && (
                          <div class="tool-signal-grid">
                            {ps.praise && ps.praise.length > 0 && (
                              <div>
                                <h6>Lob</h6>
                                <ul>
                                  {ps.praise.map((p) => <li>{p}</li>)}
                                </ul>
                              </div>
                            )}
                            {ps.complaints && ps.complaints.length > 0 && (
                              <div>
                                <h6>Kritik</h6>
                                <ul>
                                  {ps.complaints.map((p) => <li>{p}</li>)}
                                </ul>
                              </div>
                            )}
                          </div>
                        )}
                      </div>
                    )}
                    {toolSources.length > 0 && (
                      <div class="sources">
                        {toolSources.map((s) => (
                          s.url ? (
                            <a class="src" href={s.url} rel="noreferrer" target="_blank">
                              <span class={`badge ${s.type}`}>{s.type_label}</span>
                              {s.label}
                            </a>
                          ) : (
                            <span class="src">
                              <span class={`badge ${s.type}`}>{s.type_label}</span>
                              {s.label}
                            </span>
                          )
                        ))}
                      </div>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>

          <div class="kv"><b>Einstieg</b>{uc.start_here}</div>
          <div class="kv"><b>Vorsicht</b>{uc.caveats}</div>

          {ucSources.length > 0 && (
            <div class="kv">
              <b>Quellen</b>
              <div class="sources">
                {ucSources.map((s) => (
                  s.url ? (
                    <a class="src" href={s.url} rel="noreferrer" target="_blank">
                      <span class={`badge ${s.type}`}>{s.type_label}</span>
                      {s.label}
                    </a>
                  ) : (
                    <span class="src">
                      <span class={`badge ${s.type}`}>{s.type_label}</span>
                      {s.label}
                    </span>
                  )
                ))}
              </div>
            </div>
          )}
        </li>
        );
      })}
    </ul>
  </section>

  <section class="stage-detail-section stage-detail-prose">
    <Content />
  </section>

  {standalone ? (
    <p>
      <a class="stage-detail-backlink" href="/">← Zurück zum Atlas</a>
    </p>
  ) : (
    <p>
      <a class="stage-detail-backlink" href={`/stage/${stage.slug}`}>
        → Eigene Seite öffnen
      </a>
    </p>
  )}
</article>
