---
import type { CollectionEntry } from 'astro:content';
import SuitabilityBadge from './SuitabilityBadge.astro';
import UseCaseDetailSections from './UseCaseDetailSections.astro';
import type { ToolEntry, SourceEntry } from '../lib/data';
import { buildUseCaseDetailView } from '../lib/use-case-detail';

type CoverageKey = 'strong' | 'ok' | 'thin' | 'open';

interface Props {
  stage: CollectionEntry<'stages'>;
  useCases: CollectionEntry<'use_cases'>[];
  tools: ToolEntry[];
  sources: SourceEntry[];
  standalone?: boolean;
}

const { stage, useCases: useCaseEntries, tools, sources, standalone = false } = Astro.props;
const { Content } = await stage.render();

const toolsById = new Map(tools.map((tool) => [tool.id, tool] as const));
const sourcesById = new Map(sources.map((source) => [source.id, source] as const));

const coverageLabels: Record<CoverageKey, string> = {
  strong: 'stark abgedeckt',
  ok: 'brauchbar abgedeckt',
  thin: 'dünn abgedeckt',
  open: 'noch offen',
};

const coverageTooltipText: Record<CoverageKey, string> = {
  strong:
    'Stark abgedeckt: Mehrere passende Tools sind recherchiert und mindestens eine Option ist auch fuer Teams oder Enterprise tragfaehig. Bewertet nach Zahl passender Tools und ihrer Enterprise-Tauglichkeit.',
  ok:
    'Brauchbar abgedeckt: Es gibt gute Optionen, aber die Auswahl ist noch begrenzt. Bewertet nach Zahl passender Tools und ihrer Enterprise-Tauglichkeit.',
  thin:
    'Duenn abgedeckt: Nur wenige Tools passen wirklich gut. Bewertet nach Zahl passender Tools und ihrer Enterprise-Tauglichkeit.',
  open:
    'Noch offen: Die Tool-Recherche ist noch unvollstaendig oder nicht belastbar genug. Bewertet nach Zahl passender Tools und ihrer Enterprise-Tauglichkeit.',
};

function computeToolCoverage(uc: CollectionEntry<'use_cases'>['data']): CoverageKey {
  if (uc.tools.length === 0) return 'open';

  const fitCovered = uc.tools.filter(
    (tool) => tool.fit === 'good_fit' || tool.fit === 'conditional'
  );
  const goodFit = uc.tools.filter((tool) => tool.fit === 'good_fit');
  const enterpriseUsable = uc.tools.filter(
    (tool) =>
      tool.enterprise_readiness === 'enterprise_ready' ||
      tool.enterprise_readiness === 'team_ready'
  );

  if (fitCovered.length >= 3 && goodFit.length >= 2 && enterpriseUsable.length >= 1) {
    return 'strong';
  }

  if (fitCovered.length >= 2 && enterpriseUsable.length >= 1) {
    return 'ok';
  }

  if (fitCovered.length >= 1) return 'thin';
  return 'open';
}

const useCases = useCaseEntries.map((entry) => ({
  data: entry.data,
  detail: buildUseCaseDetailView(entry.data, sourcesById),
}));
---
<article class={`stage-detail-body${standalone ? ' standalone' : ''}`}>
  {!standalone && (
    <>
      <div class="stage-crumb">Atlas · Stage-Detail</div>
      <header class="stage-detail-header">
        <h2 class="stage-detail-title">{stage.data.name}</h2>
      </header>
      <p class="stage-verdict">{stage.data.challenge}</p>
    </>
  )}

  <section class="stage-detail-section">
    <h3>
      Use Cases
      <span class="count">{useCaseEntries.length} Einträge</span>
    </h3>
    <div class="stage-ucs">
      {useCases.map(({ data: uc, detail }) => {
        const coverage = computeToolCoverage(uc);
        const coverageTooltip = coverageTooltipText[coverage];

        return (
          <details class="stage-uc">
            <summary class="stage-uc-head">
              <span class="stage-uc-title">{uc.title}</span>
              <span class="stage-uc-pill-slot">
                <SuitabilityBadge suitability={uc.suitability} context="ai" />
                <span
                  class={`pill coverage coverage-${coverage}${coverage === 'strong' ? ' is-default' : ''}`}
                  role="img"
                  title={coverageTooltip}
                  aria-label={`${coverageLabels[coverage]}. ${coverageTooltip}`}
                  aria-hidden={coverage === 'strong' ? 'true' : 'false'}
                >
                  <span class="bars" aria-hidden="true"
                    ><span></span><span></span><span></span><span></span></span>
                  {coverageLabels[coverage]}
                </span>
              </span>
              <span class="stage-uc-tools-line">
                <span class="label">Tools ({uc.tools.length})</span>
                {uc.tools
                  .map((entry) => toolsById.get(entry.id)?.name)
                  .filter((name): name is string => Boolean(name))
                  .join(' · ')}
              </span>
              <span class="stage-uc-caret" aria-hidden="true">
                Details
                <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
                  <path
                    d="M1 1l4 4 4-4"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                  ></path>
                </svg>
              </span>
            </summary>

            <div class="stage-uc-body">
              <UseCaseDetailSections useCase={detail} toolsById={toolsById} />
            </div>
          </details>
        );
      })}
    </div>
  </section>

  <section class="stage-detail-section stage-detail-prose">
    <Content />
  </section>

  {standalone ? (
    <p>
      <a class="stage-detail-backlink" href="/">← Zurück zum Atlas</a>
    </p>
  ) : (
    <p>
      <a class="stage-detail-backlink" href={`/stage/${stage.slug}`}>
        → Eigene Seite öffnen
      </a>
    </p>
  )}
</article>
