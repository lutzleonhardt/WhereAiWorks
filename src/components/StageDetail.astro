---
import type { CollectionEntry } from 'astro:content';
import SuitabilityBadge from './SuitabilityBadge.astro';

type ToolEntry = {
  id: string;
  name: string;
  url: string;
  maturity: 'production' | 'experimental';
  pricing?: string;
};

interface Props {
  stage: CollectionEntry<'stages'>;
  useCases: CollectionEntry<'use_cases'>[];
  tools: ToolEntry[];
  standalone?: boolean;
}

const { stage, useCases: useCaseEntries, tools, standalone = false } = Astro.props;
const { Content } = await stage.render();

const toolsById = new Map(tools.map((t) => [t.id, t] as const));

const maturityLabels: Record<string, string> = {
  production: 'stable',
  experimental: 'growing',
};

const useCases = useCaseEntries.map((entry) => entry.data);
---
<article class="stage-detail-body">
  <div class="stage-crumb">Atlas · Stage-Detail</div>
  <header class="stage-detail-header">
    <h2 class="stage-detail-title">{stage.data.name}</h2>
  </header>
  <p class="stage-verdict">{stage.data.challenge}</p>

  <section class="stage-detail-section">
    <h3>
      Use Cases
      <span class="count">{useCases.length} Einträge</span>
    </h3>
    <ul class="ucs">
      {useCases.map((uc) => (
        <li class="uc">
          <h4>{uc.title}</h4>
          <div class="goal">„{uc.goal_label}"</div>
          <div class="row">
            <SuitabilityBadge suitability={uc.suitability} />
          </div>
          <p class="why">{uc.rationale}</p>

          <div class="kv">
            <b>Tools</b>
            <div class="chips">
              {uc.tools.map((entry) => {
                const tool = toolsById.get(entry.id);
                if (!tool) return null;
                return (
                  <a
                    class="chip"
                    href={tool.url}
                    rel="noreferrer"
                    target="_blank"
                  >
                    {tool.name}
                    <span class="mat">({maturityLabels[tool.maturity]})</span>
                    {entry.note && <span class="chip-note"> — {entry.note}</span>}
                  </a>
                );
              })}
            </div>
          </div>

          <div class="kv"><b>Einstieg</b>{uc.start_here}</div>
          <div class="kv"><b>Vorsicht</b>{uc.caveats}</div>

          {uc.sources.length > 0 && (
            <div class="kv">
              <b>Quellen</b>
              <div class="sources">
                {uc.sources.map((s) => (
                  s.url ? (
                    <a class="src" href={s.url} rel="noreferrer" target="_blank">
                      <span class={`badge ${s.type}`}>{s.type.replace('_', ' ')}</span>
                      {s.label}
                    </a>
                  ) : (
                    <span class="src">
                      <span class={`badge ${s.type}`}>{s.type.replace('_', ' ')}</span>
                      {s.label}
                    </span>
                  )
                ))}
              </div>
            </div>
          )}
        </li>
      ))}
    </ul>
  </section>

  <section class="stage-detail-section stage-detail-prose">
    <Content />
  </section>

  {standalone ? (
    <p>
      <a class="stage-detail-backlink" href="/">← Zurück zum Atlas</a>
    </p>
  ) : (
    <p>
      <a class="stage-detail-backlink" href={`/stage/${stage.slug}`}>
        → Eigene Seite öffnen
      </a>
    </p>
  )}
</article>
