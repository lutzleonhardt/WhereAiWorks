---
import type { CollectionEntry } from 'astro:content';

interface Props {
  stage: CollectionEntry<'stages'>;
}

const { stage } = Astro.props;
const { name, challenge, top_use_case, roles, order } = stage.data;
const idx = String(order).padStart(2, '0');
---
<a
  class="stage"
  href={`/stage/${stage.slug}`}
  data-stage={stage.slug}
  data-roles={roles.join(',')}
  role="listitem"
>
  <span class="arrow">
    <span class="idx">Stufe {idx}</span>
    <span class="name">{name}</span>
    <span class="challenge">{challenge}</span>
    <span class="topuc">
      Top Use Case
      <b>{top_use_case}</b>
    </span>
  </span>
</a>
