---
import { getCollection, getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import { loadRoles, loadSources, loadTools } from '../lib/data';

const roles = loadRoles();
const tools = loadTools();
const sources = loadSources();
const toolsById = new Map(tools.map((t) => [t.id, t] as const));
const sourcesById = new Map(sources.map((s) => [s.id, s] as const));

const suitabilityColor: Record<string, string> = {
  good_fit: 'green',
  conditional: 'amber',
  partial: 'orange',
  immature: 'red',
};

const suitabilityLabels: Record<string, string> = {
  good_fit: 'gut geeignet',
  conditional: 'bedingt geeignet',
  partial: 'nur Teilaufgaben',
  immature: 'noch unreif',
};

const maturityLabels: Record<string, string> = {
  production: 'stable',
  experimental: 'growing',
};

const sourceTypeLabels: Record<string, string> = {
  study: 'study',
  case_study: 'case study',
  vendor: 'vendor',
  community: 'community',
};

const useCaseEntries = await getCollection('use_cases');

type FinderSource = { label: string; url?: string; type: string; type_label: string };

type FinderTool = {
  id: string;
  name: string;
  url: string;
  maturity: string;
  maturity_label: string;
  note?: string;
};

type FinderUseCase = {
  id: string;
  title: string;
  roles: string[];
  goal_label: string;
  stage_id: string;
  stage_name: string;
  stage_order: number;
  suitability: string;
  suitability_label: string;
  suitability_color: string;
  rationale: string;
  tools: FinderTool[];
  start_here: string;
  caveats: string;
  sources: FinderSource[];
};

const resolveSources = (refs: readonly { id: string }[]): FinderSource[] =>
  refs
    .map((r) => sourcesById.get(r.id))
    .filter((s): s is NonNullable<typeof s> => Boolean(s))
    .map((s) => ({
      label: s.label,
      url: s.url,
      type: s.type,
      type_label: sourceTypeLabels[s.type],
    }));

type Assembled = FinderUseCase & { _stageOrder: number; _ucOrder: number };

const assembled: Assembled[] = await Promise.all(
  useCaseEntries.map(async (entry) => {
    const stage = await getEntry(entry.data.stage);
    const slug = entry.slug.split('/').pop()!;
    const uc = entry.data;
    return {
      id: `${stage.slug}:${slug}`,
      title: uc.title,
      roles: uc.roles,
      goal_label: uc.goal_label,
      stage_id: stage.slug,
      stage_name: stage.data.name,
      suitability: uc.suitability,
      suitability_label: suitabilityLabels[uc.suitability],
      suitability_color: suitabilityColor[uc.suitability],
      rationale: uc.rationale,
      tools: uc.tools
        .map((entryTool) => {
          const tool = toolsById.get(entryTool.id);
          if (!tool) return null;
          const enriched: FinderTool = {
            id: tool.id,
            name: tool.name,
            url: tool.url,
            maturity: tool.maturity,
            maturity_label: maturityLabels[tool.maturity],
          };
          if (entryTool.note) enriched.note = entryTool.note;
          return enriched;
        })
        .filter((t): t is FinderTool => t !== null),
      start_here: uc.start_here,
      caveats: uc.caveats,
      sources: resolveSources(uc.sources),
      _stageOrder: stage.data.order,
      _ucOrder: uc.order,
    };
  })
);

assembled.sort((a, b) => {
  if (a._stageOrder !== b._stageOrder) return a._stageOrder - b._stageOrder;
  return a._ucOrder - b._ucOrder;
});

const useCaseData: FinderUseCase[] = assembled.map(
  ({ _stageOrder, _ucOrder, ...rest }) => rest
);
---
<Base title="Where AI Works — Finder">
  <section id="view-finder">
    <div class="wrap">
      <div class="lede">
        <div class="eyebrow">Finder · Kann AI mir helfen?</div>
        <h1>Zwei Fragen. Eine ehrliche <em>Einschätzung.</em></h1>
        <p class="kicker">
          Wähle deine Rolle und das, was du erreichen willst. Du bekommst die
          passende Stufe im Atlas, eine Eignungs-Bewertung, einen konkreten
          Low-Risk-Einstieg und die Grenzen, die du kennen solltest.
        </p>
      </div>

      <div class="finder-wrap">
        <div class="finder-q">
          <div class="q">
            <label for="finder-role">
              <span class="n">01</span> Ich bin:
            </label>
            <select id="finder-role">
              <option value="">Rolle wählen…</option>
              {roles.map((r) => (
                <option value={r.id}>{r.name}</option>
              ))}
            </select>
          </div>
          <div class="q">
            <label for="finder-goal">
              <span class="n">02</span> Ich will:
            </label>
            <select id="finder-goal" disabled>
              <option value="">Zuerst Rolle wählen</option>
            </select>
          </div>
        </div>

        <div id="finder-empty" class="finder-empty">
          Wähle Rolle und Ziel, um eine Einschätzung zu erhalten.
        </div>
        <div
          id="finder-result"
          class="finder-result"
          hidden
          aria-live="polite"
        ></div>
      </div>
    </div>
  </section>

  <script define:vars={{ useCaseData }}>
    // @ts-nocheck
    window.__FINDER_DATA__ = useCaseData;
  </script>

  <script>
    type FinderSource = {
      label: string;
      url?: string;
      type: string;
      type_label: string;
    };
    type FinderTool = {
      id: string;
      name: string;
      url: string;
      maturity: string;
      maturity_label: string;
      note?: string;
    };
    type FinderUseCase = {
      id: string;
      title: string;
      roles: string[];
      goal_label: string;
      stage_id: string;
      stage_name: string;
      suitability: string;
      suitability_label: string;
      suitability_color: string;
      rationale: string;
      tools: FinderTool[];
      start_here: string;
      caveats: string;
      sources: FinderSource[];
    };

    const data =
      (window as unknown as { __FINDER_DATA__: FinderUseCase[] }).__FINDER_DATA__ || [];
    const roleSel = document.getElementById('finder-role') as HTMLSelectElement;
    const goalSel = document.getElementById('finder-goal') as HTMLSelectElement;
    const result = document.getElementById('finder-result') as HTMLElement;
    const empty = document.getElementById('finder-empty') as HTMLElement;

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string)
      );
    }

    function pillHtml(color: string, label: string, size = ''): string {
      return `<span class="pill ${color} ${size}" role="status"><span class="dot" aria-hidden="true"></span>${escapeHtml(label)}</span>`;
    }

    function chipsHtml(ts: FinderTool[]): string {
      if (!ts.length) return '<p>—</p>';
      return `<div class="chips">${ts
        .map((t) => {
          const note = t.note ? ` <span class="chip-note">— ${escapeHtml(t.note)}</span>` : '';
          return `<a class="chip" href="${escapeHtml(t.url)}" rel="noreferrer" target="_blank">${escapeHtml(t.name)} <span class="mat">(${escapeHtml(t.maturity_label)})</span>${note}</a>`;
        })
        .join('')}</div>`;
    }

    function sourcesHtml(ss: FinderSource[]): string {
      if (!ss.length) return '<p>—</p>';
      return `<div class="sources">${ss
        .map((s) => {
          const body = `<span class="badge ${escapeHtml(s.type)}">${escapeHtml(s.type_label)}</span>${escapeHtml(s.label)}`;
          return s.url
            ? `<a class="src" href="${escapeHtml(s.url)}" rel="noreferrer" target="_blank">${body}</a>`
            : `<span class="src">${body}</span>`;
        })
        .join('')}</div>`;
    }

    function showResult(uc: FinderUseCase) {
      empty.hidden = true;
      result.hidden = false;
      result.innerHTML = `
        <div class="crumb">Ergebnis · Finder</div>
        <h2>
          ${escapeHtml(uc.title)}
          <a class="stage-link" href="/#stage-${escapeHtml(uc.stage_id)}">→ Im Atlas anzeigen</a>
        </h2>
        <div class="row-top">
          ${pillHtml(uc.suitability_color, uc.suitability_label, 'lg')}
          <span class="pill"><span class="dot" style="background:var(--accent)" aria-hidden="true"></span>Stufe: ${escapeHtml(uc.stage_name)}</span>
        </div>
        <p class="why">${escapeHtml(uc.rationale)}</p>

        <div class="grid">
          <div>
            <h4>Empfohlene Tools</h4>
            ${chipsHtml(uc.tools)}

            <h4>Womit anfangen?</h4>
            <p>${escapeHtml(uc.start_here)}</p>
          </div>
          <div>
            <h4>Vorsicht / Grenzen</h4>
            <p>${escapeHtml(uc.caveats)}</p>

            <h4>Quellen</h4>
            ${sourcesHtml(uc.sources)}
          </div>
        </div>
      `;
    }

    function reset() {
      result.hidden = true;
      result.innerHTML = '';
      empty.hidden = false;
    }

    roleSel.addEventListener('change', () => {
      const role = roleSel.value;
      reset();
      goalSel.innerHTML = '';
      if (!role) {
        goalSel.disabled = true;
        goalSel.appendChild(new Option('Zuerst Rolle wählen', ''));
        return;
      }
      const goals = data.filter((uc) => uc.roles.includes(role));
      goalSel.disabled = goals.length === 0;
      goalSel.appendChild(new Option('Ziel wählen…', ''));
      goals.forEach((uc) => goalSel.appendChild(new Option(uc.goal_label, uc.id)));
    });

    goalSel.addEventListener('change', () => {
      const uc = data.find((d) => d.id === goalSel.value);
      if (!uc) {
        reset();
        return;
      }
      showResult(uc);
    });
  </script>
</Base>
