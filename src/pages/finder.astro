---
import Base from '../layouts/Base.astro';
import { loadRoles } from '../lib/data';
import { loadFinderOptions } from '../lib/finder';

const roles = loadRoles();
const finderOptions = await loadFinderOptions();
---
<Base title="Where AI Works — Finder">
  <section id="view-finder">
    <div class="wrap">
      <div class="lede">
        <div class="eyebrow">Finder · Kann AI mir helfen?</div>
        <h1>Zwei Fragen. Eine ehrliche <em>Einschätzung.</em></h1>
        <p class="kicker">
          Wähle deine Rolle und das, was du erreichen willst. Du bekommst die
          passende Stufe im Atlas, eine Eignungs-Bewertung, einen konkreten
          Low-Risk-Einstieg und die Grenzen, die du kennen solltest.
        </p>
      </div>

      <div class="finder-wrap">
        <div class="finder-q">
          <div class="q">
            <label for="finder-role">
              <span class="n">01</span> Ich bin:
            </label>
            <select id="finder-role">
              <option value="">Rolle wählen…</option>
              {roles.map((role) => (
                <option value={role.id}>{role.name}</option>
              ))}
            </select>
          </div>
          <div class="q">
            <label for="finder-goal">
              <span class="n">02</span> Ich will:
            </label>
            <select id="finder-goal" disabled>
              <option value="">Zuerst Rolle wählen</option>
            </select>
          </div>
        </div>

        <div id="finder-empty" class="finder-empty">
          Wähle Rolle und Ziel, um eine Einschätzung zu erhalten.
        </div>

        <div id="finder-result" class="finder-result" hidden aria-live="polite"></div>
      </div>
    </div>
  </section>

  <script define:vars={{ finderOptions }}>
    const data = Array.isArray(finderOptions) ? finderOptions : [];

    function initFinder() {
      const roleSel = document.getElementById('finder-role');
      const goalSel = document.getElementById('finder-goal');
      const result = document.getElementById('finder-result');
      const empty = document.getElementById('finder-empty');

      if (!roleSel || !goalSel || !result || !empty) {
        return;
      }

      if (roleSel.dataset.finderBound === 'true') {
        return;
      }

      roleSel.dataset.finderBound = 'true';
      const finderCache = window.__finderCache || (window.__finderCache = new Map());
      let activeRequest = 0;

      function updateUrl(role, goal) {
        const url = new URL(window.location.href);
        if (role) {
          url.searchParams.set('role', role);
        } else {
          url.searchParams.delete('role');
        }

        if (goal) {
          url.searchParams.set('goal', goal);
        } else {
          url.searchParams.delete('goal');
        }

        window.history.replaceState({}, '', url);
      }

      function getGoalsForRole(role) {
        return data.filter((useCase) => useCase.roles.includes(role));
      }

      function fillGoalOptions(goals, selectedGoal = '') {
        goalSel.innerHTML = '';
        goalSel.appendChild(new Option('Ziel wählen…', ''));
        goals.forEach((useCase) => {
          goalSel.appendChild(new Option(useCase.goal_label, useCase.id));
        });
        goalSel.disabled = goals.length === 0;
        if (selectedGoal && goals.some((useCase) => useCase.id === selectedGoal)) {
          goalSel.value = selectedGoal;
        }
      }

      function showEmpty() {
        result.hidden = true;
        result.innerHTML = '';
        empty.hidden = false;
      }

      function showLoading() {
        empty.hidden = true;
        result.hidden = false;
        result.innerHTML = `
          <div class="finder-result-card finder-result-status">
            <div class="crumb">Ergebnis · Finder</div>
            <p>Lade Einschätzung…</p>
          </div>
        `;
      }

      function showError() {
        empty.hidden = true;
        result.hidden = false;
        result.innerHTML = `
          <div class="finder-result-card finder-result-status finder-result-error">
            <div class="crumb">Ergebnis · Finder</div>
            <p>Das Ergebnis konnte gerade nicht geladen werden. Bitte erneut versuchen.</p>
          </div>
        `;
      }

      function prefetchGoals(goals) {
        goals.forEach((useCase) => {
          if (finderCache.has(useCase.result_path)) return;
          fetch(useCase.result_path)
            .then((response) => (response.ok ? response.text() : null))
            .then((html) => {
              if (html) finderCache.set(useCase.result_path, html);
            })
            .catch(() => {});
        });
      }

      async function renderResult(goalId) {
        const useCase = data.find((entry) => entry.id === goalId);
        if (!useCase) {
          showEmpty();
          return;
        }

        const requestId = ++activeRequest;
        const cached = finderCache.get(useCase.result_path);

        if (cached) {
          empty.hidden = true;
          result.hidden = false;
          result.innerHTML = cached;
          return;
        }

        showLoading();

        try {
          const response = await fetch(useCase.result_path);
          if (!response.ok) throw new Error(`Failed to fetch ${useCase.result_path}`);
          const html = await response.text();
          finderCache.set(useCase.result_path, html);

          if (requestId !== activeRequest) {
            return;
          }

          empty.hidden = true;
          result.hidden = false;
          result.innerHTML = html;
        } catch (_error) {
          if (requestId !== activeRequest) {
            return;
          }
          showError();
        }
      }

      roleSel.addEventListener('change', () => {
        const role = roleSel.value;
        activeRequest += 1;

        if (!role) {
          goalSel.innerHTML = '';
          goalSel.disabled = true;
          goalSel.appendChild(new Option('Zuerst Rolle wählen', ''));
          updateUrl('', '');
          showEmpty();
          return;
        }

        const goals = getGoalsForRole(role);
        fillGoalOptions(goals);
        updateUrl(role, '');
        showEmpty();
        prefetchGoals(goals);
      });

      goalSel.addEventListener('change', () => {
        const role = roleSel.value;
        if (!goalSel.value) {
          activeRequest += 1;
          updateUrl(role, '');
          showEmpty();
          return;
        }

        updateUrl(role, goalSel.value);
        renderResult(goalSel.value);
      });

      const url = new URL(window.location.href);
      const initialRole = url.searchParams.get('role') || '';
      const initialGoal = url.searchParams.get('goal') || '';

      if (initialRole) {
        roleSel.value = initialRole;
        const goals = getGoalsForRole(initialRole);
        fillGoalOptions(goals, initialGoal);
        prefetchGoals(goals);

        if (initialGoal && goals.some((useCase) => useCase.id === initialGoal)) {
          renderResult(initialGoal);
        } else {
          updateUrl(initialRole, '');
          showEmpty();
        }
      }
    }

    document.addEventListener('astro:page-load', initFinder);
    initFinder();
  </script>
</Base>
