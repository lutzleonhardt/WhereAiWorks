---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StageDetail from '../../components/StageDetail.astro';
import { loadSources, loadTools } from '../../lib/data';

export const getStaticPaths: GetStaticPaths = async () => {
  const stages = await getCollection('stages');
  return stages.map((stage) => ({
    params: { id: stage.slug },
    props: { stage },
  }));
};

const { stage } = Astro.props;
const tools = loadTools();
const sources = loadSources();
const idx = String(stage.data.order).padStart(2, '0');
const useCases = (
  await getCollection('use_cases', (uc) => uc.data.stage.id === stage.slug)
).sort((a, b) => a.data.order - b.data.order);

// Mini-Phasenleiste oben — gleiche vier Phasen wie auf der Atlas-Seite,
// aktuelle Phase markiert. Bewusst kompakt, kein zweites Atlas.
const phases = [
  { id: 'entwickeln', label: 'Entwickeln' },
  { id: 'betreiben', label: 'Betreiben' },
  { id: 'begleiten', label: 'Begleiten' },
  { id: 'wachsen', label: 'Wachsen' },
] as const;
const currentPhase = stage.data.phase;
---
<Base title={`${stage.data.name} — Where AI Works`}>
  <section>
    <div class="wrap">
      <nav class="phase-strip" aria-label="Phase">
        <a class="phase-strip-back" href="/">← Atlas</a>
        <ol class="phase-strip-list">
          {phases.map((p) => (
            <li
              class:list={[
                'phase-strip-item',
                p.id === currentPhase && 'is-current',
              ]}
            >
              <a href={`/#phase-${p.id}`}>{p.label}</a>
            </li>
          ))}
        </ol>
      </nav>

      <div class="lede">
        <div class="eyebrow">Atlas · Stufe {idx}</div>
        <h1>{stage.data.name}</h1>
        <p class="kicker">{stage.data.challenge}</p>
      </div>

      <div class="stage-detail standalone">
        <StageDetail stage={stage} useCases={useCases} tools={tools} sources={sources} standalone />
      </div>
    </div>
  </section>
</Base>
