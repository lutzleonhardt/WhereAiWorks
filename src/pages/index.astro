---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import StageCard from '../components/StageCard.astro';
import { loadRoles } from '../lib/data';

const roles = loadRoles();

const stages = (await getCollection('stages')).sort(
  (a, b) => a.data.order - b.data.order
);

// Phasen über die Wertschöpfungskette. Reihenfolge bewusst: erst was wir
// bauen, dann was wir betreiben, dann was wir um den Kunden herum tun,
// dann wie wir das Geschäft skalieren.
const phases = [
  {
    id: 'entwickeln',
    label: 'Entwickeln',
    hint: 'Vom Kundenproblem zum getesteten Inkrement.',
  },
  {
    id: 'betreiben',
    label: 'Betreiben',
    hint: 'Was läuft, muss laufen — verlässlich und sichtbar.',
  },
  {
    id: 'begleiten',
    label: 'Begleiten',
    hint: 'Kunden bekommen Antworten — schnell und konsistent.',
  },
  {
    id: 'wachsen',
    label: 'Wachsen',
    hint: 'Neue Kunden, neue Köpfe — skalierbare Texte und Prozesse.',
  },
] as const;

const stagesByPhase = phases.map((phase) => ({
  ...phase,
  items: stages.filter((s) => s.data.phase === phase.id),
}));

const pad = (n: number) => String(n).padStart(2, '0');

const useCaseCount = (await getCollection('use_cases')).length;
---
<Base title="Where AI Works — Atlas">
  <section id="view-atlas">
    <div class="wrap">
      <div class="lede">
        <div class="eyebrow">Atlas · Wertschöpfungskette</div>
        <h1>
          Wo schafft AI in Softwareunternehmen heute
          <em>realen Mehrwert</em> — und wo nicht?
        </h1>
        <p class="kicker">
          Eine kuratierte Orientierung für CTOs, Product Owners, Team Leads und
          Engineers im Mittelstand. Vier Stufen entlang der Wertschöpfung.
          Ehrliche Einordnung statt Hype — inklusive der Stellen, an denen AI
          heute noch scheitert.
        </p>
        <div class="meta">
          <span>{stages.length} Stufen · {useCaseCount} Use Cases</span>
          <span>Open Source · Lizenz TBD</span>
        </div>
      </div>

      <div class="filter-row">
        <label for="role-filter">Rolle</label>
        <select id="role-filter" aria-describedby="filter-hint">
          <option value="all">Alle Rollen</option>
          {roles.map((r) => (
            <option value={r.id}>{r.name}</option>
          ))}
        </select>
        <span class="filter-hint" id="filter-hint">
          Nicht-passende Stufen werden abgedunkelt, bleiben aber sichtbar.
        </span>
      </div>

      <div
        class="chain-wrap"
        id="chain"
        role="list"
        aria-label="Wertschöpfungskette mit Stufen"
      >
        {stagesByPhase.map((phase) => phase.items.length > 0 && (
          <section class="phase-group" data-phase={phase.id} aria-labelledby={`phase-${phase.id}`}>
            <header class="phase-header">
              <span class="phase-num">{
                phase.items.length > 1
                  ? `Stufe ${pad(phase.items[0].data.order)} – ${pad(phase.items[phase.items.length - 1].data.order)}`
                  : `Stufe ${pad(phase.items[0].data.order)}`
              }</span>
              <h2 class="phase-label" id={`phase-${phase.id}`}>{phase.label}</h2>
              <p class="phase-hint">{phase.hint}</p>
            </header>
            <div class="chain phase-chain" data-count={phase.items.length}>
              {phase.items.map((stage) => (
                <StageCard stage={stage} />
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <script>
    // Role filter — dims stages whose data-roles does not include the
    // selected role. Re-bound after each View-Transition so the listener
    // survives client-side navigation back to the Atlas.
    function bindRoleFilter() {
      const filter = document.getElementById('role-filter') as HTMLSelectElement | null;
      if (!filter) return;
      const cards = document.querySelectorAll<HTMLElement>('.stage');
      filter.addEventListener('change', (e) => {
        const role = (e.target as HTMLSelectElement).value;
        cards.forEach((card) => {
          const roles = (card.dataset.roles || '')
            .split(',')
            .map((s) => s.trim())
            .filter(Boolean);
          const match = role === 'all' || roles.includes(role);
          card.classList.toggle('dimmed', !match);
        });
      });
    }
    bindRoleFilter();
    document.addEventListener('astro:page-load', bindRoleFilter);
  </script>
</Base>
