---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import StageCard from '../components/StageCard.astro';
import StageDetail from '../components/StageDetail.astro';
import { loadRoles, loadSources, loadTools } from '../lib/data';

const roles = loadRoles();
const tools = loadTools();
const sources = loadSources();

const stages = (await getCollection('stages')).sort(
  (a, b) => a.data.order - b.data.order
);

const allUseCases = await getCollection('use_cases');
const useCasesByStage = new Map<string, typeof allUseCases>();
for (const uc of allUseCases) {
  const slug = uc.data.stage.id;
  const list = useCasesByStage.get(slug);
  if (list) list.push(uc);
  else useCasesByStage.set(slug, [uc]);
}
for (const list of useCasesByStage.values()) {
  list.sort((a, b) => a.data.order - b.data.order);
}

const useCaseCount = allUseCases.length;
---
<Base title="Where AI Works — Atlas">
  <section id="view-atlas">
    <div class="wrap">
      <div class="lede">
        <div class="eyebrow">Atlas · Wertschöpfungskette</div>
        <h1>
          Wo schafft AI in Softwareunternehmen heute
          <em>realen Mehrwert</em> — und wo nicht?
        </h1>
        <p class="kicker">
          Eine kuratierte Orientierung für CTOs, Product Owners, Team Leads und
          Engineers im Mittelstand. Vier Stufen entlang der Wertschöpfung.
          Ehrliche Einordnung statt Hype — inklusive der Stellen, an denen AI
          heute noch scheitert.
        </p>
        <div class="meta">
          <span>{stages.length} Stufen · {useCaseCount} Use Cases</span>
          <span>Open Source · Lizenz TBD</span>
        </div>
      </div>

      <div class="filter-row">
        <label for="role-filter">Rolle</label>
        <select id="role-filter" aria-describedby="filter-hint">
          <option value="all">Alle Rollen</option>
          {roles.map((r) => (
            <option value={r.id}>{r.name}</option>
          ))}
        </select>
        <span class="filter-hint" id="filter-hint">
          Nicht-passende Stufen werden abgedunkelt, bleiben aber sichtbar.
        </span>
      </div>

      <div
        class="chain"
        id="chain"
        role="list"
        aria-label="Wertschöpfungskette mit Stufen"
      >
        {stages.map((stage) => (
          <StageCard stage={stage} />
        ))}
      </div>

      <div id="atlas" class="detail-anchor"></div>
      <div class="detail-area">
        <p class="detail-empty" id="detail-empty">
          Wähle eine Stufe, um Details zu sehen.
          <kbd>↵</kbd> oder <kbd>Klick</kbd> auf einen Pfeil.
        </p>

        {stages.map((stage) => (
          <section id={`stage-${stage.slug}`} class="stage-detail">
            <a href="#atlas" class="close-detail" aria-label="Detail schließen">
              ✕ Schließen
            </a>
            <StageDetail
              stage={stage}
              useCases={useCasesByStage.get(stage.slug) ?? []}
              tools={tools}
              sources={sources}
            />
          </section>
        ))}
      </div>
    </div>
  </section>

  <script>
    // Role filter — dims stages whose data-roles does not include the
    // selected role.
    const filter = document.getElementById('role-filter') as HTMLSelectElement | null;
    const cards = document.querySelectorAll<HTMLElement>('.stage');

    if (filter) {
      filter.addEventListener('change', (e) => {
        const role = (e.target as HTMLSelectElement).value;
        cards.forEach((card) => {
          const roles = (card.dataset.roles || '')
            .split(',')
            .map((s) => s.trim())
            .filter(Boolean);
          const match = role === 'all' || roles.includes(role);
          card.classList.toggle('dimmed', !match);
        });
      });
    }

    // Sync `.active` highlight on whichever stage is currently targeted.
    function syncActive() {
      const hash = location.hash.replace('#', '');
      const activeSlug = hash.startsWith('stage-') ? hash.slice('stage-'.length) : '';
      cards.forEach((card) => {
        card.classList.toggle('active', card.dataset.stage === activeSlug);
      });
    }
    syncActive();
    window.addEventListener('hashchange', syncActive);
  </script>
</Base>
