---
import '../styles/global.css';

interface Props {
  title: string;
  pathname?: string;
}

const { title, pathname = Astro.url.pathname } = Astro.props;

const navItems = [
  { href: '/', label: 'Atlas' },
  { href: '/finder', label: 'Finder' },
];

function isCurrent(href: string) {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href);
}
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Wo schafft AI in Softwareunternehmen realen Mehrwert — und wo (noch) nicht? Eine offene, kuratierte Orientierungshilfe." />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="site-title" href="/">Where AI Works</a>
        <nav class="site-nav" aria-label="Hauptnavigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <a href="https://github.com/" rel="noreferrer">GitHub</a> · Lizenz TBD
    </footer>
  </body>
</html>
