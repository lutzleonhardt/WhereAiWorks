---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  pathname?: string;
}

const { title, pathname = Astro.url.pathname } = Astro.props;

const navItems = [
  { href: '/', label: 'Atlas' },
  { href: '/finder', label: 'Finder' },
  { href: '/tools', label: 'Tools' },
];

function isCurrent(href: string) {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href);
}
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="Wo schafft AI in Softwareunternehmen realen Mehrwert — und wo (noch) nicht? Eine offene, kuratierte Orientierungshilfe."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap site-header-inner">
        <a class="wordmark" href="/" aria-label="Where AI Works — Startseite">
          <span class="dot" aria-hidden="true"></span>
          Where AI Works
          <span class="sub">Kuratierte Referenz</span>
        </a>
        <nav class="site-nav" aria-label="Hauptnavigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div>
          Where AI Works · Open Source ·
          Code <a href="https://github.com/lutzleonhardt/WhereAiWorks/blob/main/LICENSE" rel="noreferrer">MIT</a>
          · Inhalte <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noreferrer">CC BY-SA 4.0</a>
        </div>
        <div>
          <a href="/quellen">Quellen</a>
          <span class="footer-sep">·</span>
          <a href="/impressum">Impressum</a>
          <span class="footer-sep">·</span>
          <a href="https://github.com/lutzleonhardt/WhereAiWorks" rel="noreferrer">GitHub</a>
        </div>
        <div class="footer-maintainer">
          Kuratiert von Lutz Leonhardt ·
          <a href="https://lutzleonhardt.de" rel="noreferrer" target="_blank">lutzleonhardt.de</a>
        </div>
      </div>
    </footer>
  </body>
</html>
